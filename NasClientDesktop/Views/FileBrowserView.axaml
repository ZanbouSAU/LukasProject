<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NasClientDesktop.ViewModels"
             xmlns:views="using:NasClientDesktop.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
             x:Class="NasClientDesktop.Views.FileBrowserView"
             x:Name="BrowserRoot"
             x:DataType="vm:FileBrowserViewModel"
             DragDrop.AllowDrop="True"
             Background="{StaticResource Bg}">

    <Panel>
        <DockPanel>
            <!-- ============ 顶栏 ============ -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="mono" FontSize="18" VerticalAlignment="Center">
                        <Run Foreground="{StaticResource Copper}" Text="nas"/><Run Foreground="{StaticResource InkFaint}" Text="://"/>
                    </TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Email}" Classes="mono" FontSize="13"
                                   Foreground="{StaticResource InkMuted}" VerticalAlignment="Center"/>
                        <Button Classes="link" Content="登出本设备" Command="{Binding LogoutCommand}"/>
                        <Button Classes="link danger-link" Content="登出所有设备" Command="{Binding LogoutAllCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ 路径栏 + 工具按钮 ============ -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- shell 提示符路径栏 -->
                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <TextBlock Classes="mono" FontSize="13" Foreground="{StaticResource InkFaint}"
                                       VerticalAlignment="Center" Text="{Binding Prompt}"/>
                            <ItemsControl ItemsSource="{Binding Segments}" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PathSegmentViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="0">
                                            <TextBlock Text="/" Classes="mono" FontSize="13"
                                                       Foreground="{StaticResource InkFaint}" VerticalAlignment="Center"
                                                       IsVisible="{Binding Target, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <Button Classes="copperlink" FontSize="13" Content="{Binding Label}"
                                                    Command="{Binding $parent[ItemsControl].((vm:FileBrowserViewModel)DataContext)?.NavigateToCommand}"
                                                    CommandParameter="{Binding Target}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text=" $" Classes="mono" FontSize="13"
                                       Foreground="{StaticResource InkFaint}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 工具按钮：上传文件 + 更多▾（与网页端一致） -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Classes="ghost" Content="上传文件" Command="{Binding UploadFilesCommand}"/>
                        <Button Classes="ghost" Content="更多 ▾">
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="新建文件" Command="{Binding OpenNewFileCommand}"/>
                                    <MenuItem Header="新建目录" Command="{Binding OpenMkdirCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="上传文件夹" Command="{Binding UploadFolderCommand}"/>
                                    <MenuItem Header="上传 Zip 解压" Command="{Binding UploadZipCommand}"
                                              ToolTip.Tip="上传 zip 包并在服务端解压到当前目录"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ 文件表 ============ -->
            <Grid>
                <!-- 加载中 -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="20,40,0,0"
                            VerticalAlignment="Top" HorizontalAlignment="Left"
                            IsVisible="{Binding Loading}">
                    <TextBlock Text="正在读取目录…" Foreground="{StaticResource InkMuted}" FontSize="13"/>
                </StackPanel>

                <!-- 加载错误 -->
                <StackPanel Margin="20,40,0,0" Spacing="12" VerticalAlignment="Top"
                            IsVisible="{Binding LoadError, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="{Binding LoadError}" Foreground="{StaticResource Danger}" FontSize="13"/>
                    <Button Classes="ghost" Content="重试" Command="{Binding RetryCommand}" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- 空目录 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                            IsVisible="{Binding ShowEmpty}">
                    <TextBlock Text="（空目录）" Classes="mono" Foreground="{StaticResource InkFaint}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="把文件拖进来，或使用上方「上传文件」开始" Foreground="{StaticResource InkMuted}"
                               FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 列表 -->
                <DockPanel IsVisible="{Binding NotLoading}">
                    <!-- 表头 -->
                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1"
                            Padding="20,8" IsVisible="{Binding !ShowEmpty}">
                        <Grid ColumnDefinitions="*,120,180,170">
                            <TextBlock Grid.Column="0" Text="名称" Classes="mono" FontSize="12" Foreground="{StaticResource InkFaint}"/>
                            <TextBlock Grid.Column="1" Text="大小" Classes="mono" FontSize="12" Foreground="{StaticResource InkFaint}" HorizontalAlignment="Right" Margin="0,0,24,0"/>
                            <TextBlock Grid.Column="2" Text="修改时间" Classes="mono" FontSize="12" Foreground="{StaticResource InkFaint}" Margin="8,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="" />
                        </Grid>
                    </Border>

                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FileRowViewModel">
                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1"
                                            Padding="20,8" Background="Transparent">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="{StaticResource Panel}"/>
                                            </Style>
                                            <!-- 行操作默认半隐藏，悬停显现 -->
                                            <Style Selector="Border:pointerover StackPanel.row-actions">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="*,120,180,170">
                                            <!-- 名称：目录可进入；可预览文件可点击预览；其余纯文本 -->
                                            <Panel Grid.Column="0" VerticalAlignment="Center">
                                                <Button Classes="copperlink" Content="{Binding DisplayName}"
                                                        IsVisible="{Binding IsDirectory}"
                                                        Command="{Binding $parent[ItemsControl].((vm:FileBrowserViewModel)DataContext)?.OpenEntryCommand}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Classes="link" Foreground="{StaticResource Ink}"
                                                        FontSize="14" Content="{Binding DisplayName}"
                                                        ToolTip.Tip="在线预览"
                                                        Command="{Binding $parent[ItemsControl].((vm:FileBrowserViewModel)DataContext)?.OpenEntryCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Button.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsDirectory"/>
                                                            <Binding Path="IsPreviewable"/>
                                                        </MultiBinding>
                                                    </Button.IsVisible>
                                                </Button>
                                                <TextBlock Classes="mono" Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource Ink}" VerticalAlignment="Center">
                                                    <TextBlock.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsDirectory"/>
                                                            <Binding Path="!IsPreviewable"/>
                                                        </MultiBinding>
                                                    </TextBlock.IsVisible>
                                                </TextBlock>
                                            </Panel>

                                            <TextBlock Grid.Column="1" Text="{Binding SizeText}" Classes="mono"
                                                       Foreground="{StaticResource InkMuted}" HorizontalAlignment="Right"
                                                       Margin="0,0,24,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding TimeText}" Classes="mono"
                                                       Foreground="{StaticResource InkMuted}" Margin="8,0,0,0" VerticalAlignment="Center"/>

                                            <!-- 行操作：合并为单个「操作 ▾」下拉菜单 -->
                                            <StackPanel Grid.Column="3" Classes="row-actions" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Opacity="0.35">
                                                <Button Classes="link" Content="操作 ▾">
                                                    <Button.Flyout>
                                                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                            <MenuItem Header="{Binding PreviewActionText}"
                                                                      IsVisible="{Binding IsPreviewable}"
                                                                      Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.PreviewRowCommand}"
                                                                      CommandParameter="{Binding}"/>
                                                            <MenuItem Header="下载"
                                                                      Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.DownloadCommand}"
                                                                      CommandParameter="{Binding}"/>
                                                            <MenuItem Header="重命名"
                                                                      Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.OpenRenameCommand}"
                                                                      CommandParameter="{Binding}"/>
                                                            <MenuItem Header="移动到…"
                                                                      Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.OpenMoveCommand}"
                                                                      CommandParameter="{Binding}"/>
                                                            <MenuItem Header="复制到…"
                                                                      Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.OpenCopyCommand}"
                                                                      CommandParameter="{Binding}"/>
                                                            <Separator/>
                                                            <MenuItem Header="删除"
                                                                      Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.OpenDeleteCommand}"
                                                                      CommandParameter="{Binding}"/>
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </DockPanel>

        <!-- ============ 新建目录对话框 ============ -->
        <Border IsVisible="{Binding MkdirOpen}" Background="#99000000">
            <Border Width="420" MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                        <TextBlock Text="mkdir" Classes="mono" FontSize="13" Foreground="{StaticResource Copper}"/>
                    </Border>
                    <StackPanel Margin="20,16" Spacing="8">
                        <TextBlock Text="{Binding MkdirPrompt}" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding MkdirName}" Watermark="目录名" Name="MkdirInput"/>
                        <TextBlock Text="{Binding MkdirError}" Foreground="{StaticResource Danger}" FontSize="12"
                                   IsVisible="{Binding MkdirError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Classes="ghost" Content="取消" Command="{Binding CancelMkdirCommand}"/>
                            <Button Classes="primary" Content="创建" Command="{Binding SubmitMkdirCommand}"
                                    IsEnabled="{Binding MkdirNotBusy}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <!-- ============ 新建文件对话框 ============ -->
        <Border IsVisible="{Binding NewFileOpen}" Background="#99000000">
            <Border Width="420" MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                        <TextBlock Text="new file" Classes="mono" FontSize="13" Foreground="{StaticResource Copper}"/>
                    </Border>
                    <StackPanel Margin="20,16" Spacing="8">
                        <TextBlock Text="{Binding NewFilePrompt}" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding NewFileName}" Watermark="文件名（含扩展名，如 notes.txt）"/>
                        <TextBlock Text="{Binding NewFileError}" Foreground="{StaticResource Danger}" FontSize="12"
                                   IsVisible="{Binding NewFileError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Classes="ghost" Content="取消" Command="{Binding CancelNewFileCommand}"/>
                            <Button Classes="primary" Content="创建" Command="{Binding SubmitNewFileCommand}"
                                    IsEnabled="{Binding NewFileNotBusy}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <!-- ============ 重命名对话框 ============ -->
        <Border IsVisible="{Binding HasRenameTarget}" Background="#99000000">
            <Border Width="420" MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                        <TextBlock Text="rename" Classes="mono" FontSize="13" Foreground="{StaticResource Copper}"/>
                    </Border>
                    <StackPanel Margin="20,16" Spacing="8">
                        <TextBlock Text="{Binding RenamePrompt}" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding RenameName}" Watermark="新名称"/>
                        <TextBlock Text="{Binding RenameError}" Foreground="{StaticResource Danger}" FontSize="12"
                                   IsVisible="{Binding RenameError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Classes="ghost" Content="取消" Command="{Binding CancelRenameCommand}"/>
                            <Button Classes="primary" Content="确定" Command="{Binding SubmitRenameCommand}"
                                    IsEnabled="{Binding RenameNotBusy}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <!-- ============ 移动/复制：目录选择器对话框 ============ -->
        <Border IsVisible="{Binding TransferActive}" Background="#99000000">
            <Border Width="460" MaxWidth="600" MaxHeight="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                        <TextBlock Text="{Binding TransferTitle}" Classes="mono" FontSize="13" Foreground="{StaticResource Copper}"/>
                    </Border>
                    <StackPanel Margin="20,16" Spacing="10">
                        <TextBlock Text="{Binding PickerDisplayPath}" Classes="mono" FontSize="13"
                                   Foreground="{StaticResource Copper}"/>

                        <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6"
                                MaxHeight="300">
                            <ScrollViewer>
                                <StackPanel>
                                    <Button Classes="link" Content="../（上级目录）"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="12,8"
                                            IsEnabled="{Binding PickerCanGoUp}"
                                            Command="{Binding PickerGoUpCommand}"/>
                                    <ItemsControl ItemsSource="{Binding PickerDirs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="link" Content="{Binding DisplayName}"
                                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                        Padding="12,8"
                                                        Foreground="{StaticResource Copper}"
                                                        Command="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.PickerEnterCommand}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Text="{Binding PickerError}" Foreground="{StaticResource Danger}" FontSize="12"
                                   IsVisible="{Binding PickerError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Classes="ghost" Content="取消" Command="{Binding CancelTransferCommand}"/>
                            <Button Classes="primary" Content="{Binding TransferConfirmText}"
                                    Command="{Binding ConfirmTransferCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <!-- ============ 删除确认对话框 ============ -->
        <Border IsVisible="{Binding HasDeleteTarget}" Background="#99000000">
            <Border Width="420" MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                        <TextBlock Text="rm" Classes="mono" FontSize="13" Foreground="{StaticResource Copper}"/>
                    </Border>
                    <StackPanel Margin="20,16" Spacing="10">
                        <TextBlock Text="{Binding DeletePromptText}" Foreground="{StaticResource Ink}"
                                   FontSize="13" TextWrapping="Wrap"/>
                        <CheckBox IsChecked="{Binding DeleteRecursive}" IsVisible="{Binding DeleteIsDirectory}"
                                  Foreground="{StaticResource InkMuted}">
                            <TextBlock Text="递归删除目录及其全部内容" FontSize="12"/>
                        </CheckBox>
                        <TextBlock Text="{Binding DeleteError}" Foreground="{StaticResource Danger}" FontSize="12"
                                   IsVisible="{Binding DeleteError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Classes="ghost" Content="取消" Command="{Binding CancelDeleteCommand}"/>
                            <Button Classes="danger" Content="删除" Command="{Binding SubmitDeleteCommand}"
                                    IsEnabled="{Binding DeleteNotBusy}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <!-- ============ 上传托盘 ============ -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,16,16"
                Width="380" MaxHeight="320"
                Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                BorderThickness="1" CornerRadius="8"
                IsVisible="{Binding Uploads.HasTasks}">
            <DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="16,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="传输任务" Classes="mono" FontSize="12"
                                   Foreground="{StaticResource InkMuted}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="link" Content="清除已完成"
                                Command="{Binding Uploads.ClearFinishedCommand}"/>
                    </Grid>
                </Border>
                <ScrollViewer MaxHeight="260">
                    <ItemsControl ItemsSource="{Binding Uploads.Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:UploadTaskViewModel">
                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="16,8">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" Classes="mono" FontSize="12"
                                                       Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Classes="mono" FontSize="12"
                                                       Foreground="{StaticResource InkMuted}" Margin="8,0,0,0"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsActive}">
                                            <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding Percent}"
                                                         IsIndeterminate="{Binding !HasPercent}"
                                                         Height="4" Foreground="{StaticResource Copper}"
                                                         Background="{StaticResource Panel2}"/>
                                            <Button Grid.Column="1" Classes="link" Content="取消" Margin="8,0,0,0"
                                                    Command="{Binding $parent[ItemsControl].((vm:FileBrowserViewModel)DataContext)?.Uploads.CancelCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto"
                                              IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <TextBlock Grid.Column="0" Text="{Binding Error}" Foreground="{StaticResource Danger}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1" Classes="link" Content="覆盖重传"
                                                    IsVisible="{Binding CanRetryOverwrite}"
                                                    Foreground="{StaticResource Copper}"
                                                    Command="{Binding $parent[ItemsControl].((vm:FileBrowserViewModel)DataContext)?.Uploads.RetryOverwriteCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ============ Toast ============ -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0"
                Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}"
                BorderThickness="1" CornerRadius="4" Padding="16,8"
                IsVisible="{Binding Toast, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{Binding Toast}" Foreground="{StaticResource Ink}" FontSize="13"/>
        </Border>

        <!-- ============ 预览模态 ============ -->
        <!-- DataContext 切到 Preview；IsVisible 经命名根元素取 FileBrowserViewModel.HasPreview。 -->
        <views:PreviewView DataContext="{Binding Preview}"
                           IsVisible="{Binding #BrowserRoot.((vm:FileBrowserViewModel)DataContext)?.HasPreview}"/>
    </Panel>
</UserControl>
