<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NasClientDesktop.ViewModels"
        xmlns:views="using:NasClientDesktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="NasClientDesktop.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/favicon.ico"
        Width="960" Height="640"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource Bg}"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- 启动恢复中的 splash -->
        <Border IsVisible="{Binding ShowSplash}" Background="{StaticResource Bg}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <TextBlock Classes="mono" FontSize="28" HorizontalAlignment="Center">
                    <Run Foreground="{StaticResource Copper}" Text="nas"/><Run Foreground="{StaticResource InkFaint}" Text="://"/>
                </TextBlock>
                <TextBlock Text="正在恢复会话…" Foreground="{StaticResource InkMuted}"
                           HorizontalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- 登录页：DataContext 切到 LoginVm；IsVisible 经命名根元素取 MainWindowViewModel.ShowLogin。 -->
        <views:LoginView DataContext="{Binding LoginVm}"
                         IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext)?.ShowLogin}"/>

        <!-- 文件浏览器：同上。 -->
        <views:FileBrowserView DataContext="{Binding BrowserVm}"
                               IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext)?.ShowBrowser}"/>
    </Panel>
</Window>
