<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NasClientDesktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
             x:Class="NasClientDesktop.Views.PreviewView"
             x:DataType="vm:PreviewViewModel">

    <Border Background="#CC000000">
        <DockPanel>
            <!-- 头部 -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="20,12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="mono" FontSize="13"
                               Foreground="{StaticResource Copper}" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Path}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Classes="link" Content="✕ 关闭"
                            Foreground="{StaticResource InkMuted}"
                            Command="{Binding CloseCommand}"/>
                </Grid>
            </Border>

            <!-- 主体 -->
            <Grid Margin="16">
                <!-- 加载中 -->
                <TextBlock Text="加载中…" Foreground="{StaticResource InkMuted}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding Loading}"/>

                <!-- 加载错误 -->
                <TextBlock Text="{Binding LoadError}" Foreground="{StaticResource Danger}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
                           IsVisible="{Binding LoadError, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <!-- 图片 -->
                <Image Source="{Binding Image}" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <!-- 媒体/外部打开提示 -->
                <Border IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                        BorderThickness="1" CornerRadius="8" Padding="28"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Spacing="8" MaxWidth="420">
                        <TextBlock Text="{Binding Name}" Classes="mono" FontSize="13"
                                   Foreground="{StaticResource InkMuted}" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Ink}" FontSize="13"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 文本编辑 -->
                <DockPanel IsVisible="{Binding IsText}">
                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SizeText}" Classes="mono" FontSize="12"
                                       Foreground="{StaticResource InkMuted}"/>
                            <TextBlock Text="● 未保存" FontSize="12" Foreground="{StaticResource Copper}"
                                       IsVisible="{Binding Dirty}"/>
                            <TextBlock Text="已保存" FontSize="12" Foreground="{StaticResource Ok}"
                                       IsVisible="{Binding SavedFlag}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SaveError}" Foreground="{StaticResource Danger}" FontSize="12"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding SaveError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            <Button Classes="primary" Content="保存 (Ctrl+S)"
                                    Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}"/>
                        </StackPanel>
                    </Grid>
                    <!-- 文本编辑器外观：要改背景色/字号就改这里的 Background 与 FontSize -->
                    <TextBox Name="TextArea" Classes="field" Text="{Binding TextValue}"
                             AcceptsReturn="True" AcceptsTab="True"
                             FontFamily="{StaticResource MonoFont}" FontSize="16"
                             Background="#1F1F1F"
                             TextWrapping="NoWrap"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
