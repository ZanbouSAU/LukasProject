<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NasClientDesktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
             x:Class="NasClientDesktop.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="{StaticResource Bg}">

    <Grid>
        <StackPanel Width="360" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
            <!-- 品牌 wordmark -->
            <TextBlock Classes="mono" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,4">
                <Run Foreground="{StaticResource Copper}" Text="nas"/><Run Foreground="{StaticResource InkFaint}" Text="://"/>
            </TextBlock>
            <TextBlock Text="你自己的那块盘" Foreground="{StaticResource InkMuted}"
                       FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <!-- 模式切换 -->
                    <Grid ColumnDefinitions="*,*" Background="{StaticResource Panel2}" Height="36">
                        <Grid.Styles>
                            <Style Selector="Button.tab">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource InkMuted}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                            <Style Selector="Button.tab.active">
                                <Setter Property="Background" Value="{StaticResource Copper}"/>
                                <Setter Property="Foreground" Value="{StaticResource Bg}"/>
                            </Style>
                        </Grid.Styles>
                        <Button Grid.Column="0" Content="登录" Classes="tab"
                                Classes.active="{Binding IsLogin}"
                                Command="{Binding SwitchToLoginCommand}"/>
                        <Button Grid.Column="1" Content="注册" Classes="tab"
                                Classes.active="{Binding IsRegister}"
                                Command="{Binding SwitchToRegisterCommand}"/>
                    </Grid>

                    <!-- 邮箱 -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="邮箱" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding Email}" Watermark="you@example.com"/>
                    </StackPanel>

                    <!-- 昵称（仅注册） -->
                    <StackPanel Spacing="5" IsVisible="{Binding IsRegister}">
                        <TextBlock Text="昵称（可选）" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding FullName}" MaxLength="50"/>
                    </StackPanel>

                    <!-- 密码 -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="密码" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding Password}" PasswordChar="•" MaxLength="128"/>
                    </StackPanel>

                    <!-- 确认密码（仅注册） -->
                    <StackPanel Spacing="5" IsVisible="{Binding IsRegister}">
                        <TextBlock Text="确认密码" Foreground="{StaticResource InkMuted}" FontSize="12"/>
                        <TextBox Classes="field" Text="{Binding Confirm}" PasswordChar="•" MaxLength="128"/>
                    </StackPanel>

                    <!-- 错误/通知 -->
                    <TextBlock Text="{Binding Error}" Foreground="{StaticResource Danger}" FontSize="13"
                               TextWrapping="Wrap" IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <TextBlock Text="{Binding Notice}" Foreground="{StaticResource Ok}" FontSize="13"
                               TextWrapping="Wrap" IsVisible="{Binding Notice, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                    <Button Classes="primary" HorizontalAlignment="Stretch" Height="40"
                            Command="{Binding SubmitCommand}" IsEnabled="{Binding NotBusy}"
                            Content="{Binding SubmitText}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="密码至少 8 位！" Foreground="{StaticResource InkFaint}"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
